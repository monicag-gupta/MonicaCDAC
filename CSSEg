<!DOCTYPE html>
<html>
<head>
    <title>Complete CSS Layout Example</title>

    <style>

        body {
            font-family: Arial;
            margin: 0;
            padding: 0;
            background-color: #f2f2f2;
        }

        /* =========================
           BLOCK ELEMENT EXAMPLE
        ========================== */

        .block-example {
            display: block;
            background-color: lightblue;
            padding: 20px;
            margin: 20px;
            border: 2px solid blue;
        }

        /* =========================
           INLINE ELEMENT EXAMPLE
        ========================== */

        .inline-example span {
            display: inline;
            background-color: yellow;
            padding: 10px;
        }

        /* =========================
           INLINE-BLOCK EXAMPLE
        ========================== */

        .inline-block-example button {
            display: inline-block;
            width: 120px;
            height: 50px;
            margin: 10px;
            background-color: green;
            color: white;
            border: none;
            font-size: 16px;
        }

        /* =========================
           RELATIVE POSITION
        ========================== */

        .relative-box {
            position: relative;
            left: 40px;
            top: 10px;

            width: 250px;
            padding: 20px;
            background-color: orange;
            border: 2px solid black;
            margin: 20px;
        }

        /* =========================
           ABSOLUTE POSITION
        ========================== */

        .parent {
            position: relative;
            width: 400px;
            height: 200px;
            background-color: lightgray;
            border: 3px solid black;
            margin: 20px;
        }

        .absolute-box {
            position: absolute;
            top: 20px;
            right: 20px;

            width: 120px;
            height: 80px;
            background-color: red;
            color: white;
            text-align: center;
            line-height: 80px;
        }

        /* =========================
           FIXED POSITION
        ========================== */

        .fixed-box {
            position: fixed;
            bottom: 20px;
            right: 20px;

            background-color: black;
            color: white;
            padding: 15px;
            border-radius: 10px;
        }

        /* =========================
           STICKY POSITION
        ========================== */

        .sticky-box {
            position: sticky;
            top: 0;

            background-color: purple;
            color: white;
            padding: 15px;
            font-size: 20px;
        }

        /* =========================
           FLEXBOX LAYOUT
        ========================== */

        .flex-container {
            display: flex;

            justify-content: space-around;
            align-items: center;
            flex-wrap: wrap;

            background-color: white;
            padding: 30px;
            margin: 20px;
            border: 2px solid gray;
        }

        .flex-item {
            width: 150px;
            height: 100px;

            background-color: teal;
            color: white;

            margin: 10px;

            display: flex;
            justify-content: center;
            align-items: center;

            font-size: 20px;
        }

        /* =========================
           EXTRA CONTENT FOR SCROLL
        ========================== */

        .content {
            height: 1000px;
            padding: 20px;
        }

    </style>

</head>

<body>

    <!-- STICKY POSITION -->
    <div class="sticky-box">
        Sticky Navigation Bar
    </div>

    <!-- BLOCK ELEMENT -->
    <div class="block-example">
        This is a BLOCK element.
    </div>

    <!-- INLINE ELEMENT -->
    <div class="inline-example">

        <span>HTML</span>
        <span>CSS</span>
        <span>JavaScript</span>

    </div>

    <br><br>

    <!-- INLINE-BLOCK ELEMENT -->
    <div class="inline-block-example">

        <button>Home</button>
        <button>About</button>
        <button>Contact</button>

    </div>

    <!-- RELATIVE POSITION -->
    <div class="relative-box">
        Relative Positioned Box
    </div>

    <!-- ABSOLUTE POSITION -->
    <div class="parent">

        Parent Container

        <div class="absolute-box">
            Absolute Box
        </div>

    </div>

    <!-- FLEXBOX -->
    <div class="flex-container">

        <div class="flex-item">1</div>
        <div class="flex-item">2</div>
        <div class="flex-item">3</div>
        <div class="flex-item">4</div>

    </div>

    <!-- EXTRA CONTENT -->
    <div class="content">

        <h2>Scroll Down</h2>

        <p>
            This content is added to demonstrate
            sticky and fixed positioning.
        </p>

    </div>

    <!-- FIXED POSITION -->
    <div class="fixed-box">
        Fixed Chat Button
    </div>

</body>
</html>








<!DOCTYPE html>
<html>
<head>

    <title>Complete Flexbox Example</title>

    <style>

        body {
            margin: 0;
            padding: 0;
            font-family: Arial;
            background-color: #f2f2f2;
        }

        /* =========================
           HEADER
        ========================== */

        .header {

            background-color: navy;
            color: white;

            padding: 20px;
            text-align: center;

            font-size: 30px;
        }

        /* =========================
           FLEX CONTAINER
        ========================== */

        .container {

            display: flex;

            /* Direction of items */
            flex-direction: row;

            /* Horizontal alignment */
            justify-content: space-evenly;

            /* Vertical alignment */
            align-items: center;

            /* Allow items to move next line */
            flex-wrap: wrap;

            /* Space between items */
            gap: 20px;

            padding: 30px;
        }

        /* =========================
           FLEX ITEMS
        ========================== */

        .card {

            width: 250px;
            height: 180px;

            background-color: white;

            border-radius: 10px;

            box-shadow: 0px 0px 10px gray;

            padding: 20px;

            /* Flex inside card */
            display: flex;

            flex-direction: column;

            justify-content: center;

            align-items: center;
        }

        .card h2 {
            color: navy;
        }

        .card p {
            text-align: center;
        }

        /* =========================
           BUTTON
        ========================== */

        .btn {

            padding: 10px 20px;

            border: none;

            background-color: teal;

            color: white;

            font-size: 16px;

            border-radius: 5px;

            cursor: pointer;
        }

        .btn:hover {
            background-color: darkcyan;
        }

        /* =========================
           SECOND FLEX EXAMPLE
        ========================== */

        .menu {

            display: flex;

            justify-content: center;

            align-items: center;

            gap: 30px;

            background-color: black;

            padding: 15px;
        }

        .menu a {

            color: white;

            text-decoration: none;

            font-size: 18px;
        }

        .menu a:hover {
            color: yellow;
        }

        /* =========================
           FOOTER
        ========================== */

        .footer {

            display: flex;

            justify-content: center;

            align-items: center;

            background-color: navy;

            color: white;

            height: 80px;

            margin-top: 30px;
        }

    </style>

</head>

<body>

    <!-- HEADER -->

    <div class="header">
        Flexbox Complete Example
    </div>

    <!-- FLEX MENU -->

    <div class="menu">

        <a href="#">Home</a>
        <a href="#">About</a>
        <a href="#">Courses</a>
        <a href="#">Contact</a>

    </div>

    <!-- FLEX CONTAINER -->

    <div class="container">

        <!-- CARD 1 -->

        <div class="card">

            <h2>HTML</h2>

            <p>
                HTML is used to create webpage structure.
            </p>

            <button class="btn">
                Learn More
            </button>

        </div>

        <!-- CARD 2 -->

        <div class="card">

            <h2>CSS</h2>

            <p>
                CSS is used to style webpages beautifully.
            </p>

            <button class="btn">
                Learn More
            </button>

        </div>

        <!-- CARD 3 -->

        <div class="card">

            <h2>JavaScript</h2>

            <p>
                JavaScript adds interactivity to webpages.
            </p>

            <button class="btn">
                Learn More
            </button>

        </div>

        <!-- CARD 4 -->

        <div class="card">

            <h2>React</h2>

            <p>
                React is used for frontend application development.
            </p>

            <button class="btn">
                Learn More
            </button>

        </div>

    </div>

    <!-- FOOTER -->

    <div class="footer">

        Flexbox Footer Layout Example

    </div>

</body>
</html>

