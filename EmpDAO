package pkg1;

import java.sql.*;

public class EmpDao {
	Connection conn;
	EmpDao() throws SQLException{
		conn = DriverManager.getConnection("jdbc:mysql://localhost:3306/mydb","root","root");
		
	}
	
	public void insert(Emp e) throws SQLException {
		String s="insert into Emp values(" + e.ecode + ",'" + e.ename+"')";
		Statement st=conn.createStatement() ;
		st.executeUpdate(s);
		
	}
}
