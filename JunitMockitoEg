package source;
public class MainClass {
	public static int findMax(int arr[]) {
		int max = 0;
		// int max=arr[0];
		for (int i = 1; i < arr.length; i++) {
			if (max < arr[i])
				max = arr[i];
		}
		return max;
	}
	public static int cube(int n) {
		return n * n * n;
	}
}







